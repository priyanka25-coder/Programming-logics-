2.12)Logic:-
a)Take two numbers.
b) Take operator (+, -, *, /).
c) Match operator.
d) Perform operation.
e) Display result.
Example:-
Input:10+20
Output:30

#C
#include <stdio.h>
int main() {
    int a, b;
    char op;
    scanf("%d %c %d", &a, &op, &b);
    if(op == '+')
        printf("%d", a + b);
    else if(op == '-')
        printf("%d", a - b);
    else if(op == '*')
        printf("%d", a * b);
    else if(op == '/')
        printf("%d", a / b);
    return 0;
}
