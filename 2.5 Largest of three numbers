2.5) Logic:-
a)Take three numbers
b)Comare all three
c)Print the largest number
Example:-
Input: 5 15 10
Output: 15 is largest

#C
#include <stdio.h>
int main() {
    int a, b, c;
    printf("Enter three numbers: ");
    scanf("%d %d %d", &a, &b, &c);
    if(a >= b && a >= c)
        printf("%d is largest", a);
    else if(b >= a && b >= c)
        printf("%d is largest", b);
    else
        printf("%d is largest", c);
    return 0;
}
