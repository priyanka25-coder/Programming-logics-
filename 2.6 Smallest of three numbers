2.6)Logic:-
a)Take three numbers.
b) Compare all three.
c) Print the smallest number.
Example:-
Input: 5 15 10
Output: 5 is smallest

#C
#include <stdio.h>
int main() {
    int a, b, c;
    scanf("%d %d %d", &a, &b, &c);
    if(a <= b && a <= c)
        printf("%d is smallest", a);
    else if(b <= a && b <= c)
        printf("%d is smallest", b);
    else
        printf("%d is smallest", c);
    return 0;
}
