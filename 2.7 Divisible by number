2.7)Logic:-
a)Take a number and divisor.
b) Check remainder using %.
c) If remainder is 0 → Divisible.
d) Else → Not Divisible.
Example:-
Input: 20 5
Output: Divisible

#C
#include <stdio.h>
int main() {
    int num, divisor;
    scanf("%d %d", &num, &divisor);
    if(num % divisor == 0)
        printf("Divisible");
    else
        printf("Not Divisible");
    return 0;
}
#Python
num = int(input())
divisor = int(input())
if num % divisor == 0:
    print("Divisible")
else:
    print("Not Divisible")
#JavaScript
let num = 20;
let divisor = 5;
if(num % divisor === 0)
    console.log("Divisible");
else
    console.log("Not Divisible");
