2.9)Logic:-
a)Take marks.
b) Compare ranges.
c) Assign grade.
Example:-
Input: 85
Output: Grade B

#C
#include <stdio.h>
int main() {
    int marks;
    scanf("%d", &marks);
    if(marks >= 90)
        printf("Grade A");
    else if(marks >= 80)
        printf("Grade B");
    else if(marks >= 70)
        printf("Grade C");
    else if(marks >= 60)
        printf("Grade D");
    else
        printf("Grade F");
    return 0;
}
#Python
